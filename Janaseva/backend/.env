# ─── Server ───
PORT=5000
NODE_ENV=development

# ─── JWT ───
JWT_SECRET=sevaone_super_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ─── Database (SQLite path) ───
DB_PATH=./sevaone.db

# ─── File Uploads ───
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# ─── Frontend URL (CORS) ───
FRONTEND_URL=http://localhost:3000,http://localhost:3001

# ─── Email (Nodemailer / SMTP) ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@sevaone.in

# ─── SMS (Msg91 / Fast2SMS) ───
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=SEVAON

# ─── Payment Gateway (Razorpay) ───
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ─── Aadhaar / DigiLocker (sandbox) ───
AADHAAR_API_URL=https://developer.uidai.gov.in
AADHAAR_API_KEY=your_aadhaar_api_key
DIGILOCKER_CLIENT_ID=your_digilocker_client_id
DIGILOCKER_CLIENT_SECRET=your_digilocker_secret
